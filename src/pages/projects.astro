---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Projects"
  description="Selected work by Mao Ratha—creator education, media, newsletters, and digital products."
>
  <header class="page-header">
    <div class="container">
      <p class="label">Work</p>
      <h1>Projects</h1>
      <p class="lead">
        Selected work across education, media, and product—built for creators
        who want to do meaningful work and get paid for it.
      </p>
    </div>
  </header>

  <section>
    <div class="container">
      <div class="project-grid">
        {
          projects.map((project) => (
            <article class="project-card project-card--featured">
              <div
                class="project-image"
                role="img"
                aria-label={`${project.title} placeholder`}
              />
              <div>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <dl class="project-meta">
                  <div>
                    <dt>Role</dt>
                    <dd>{project.role}</dd>
                  </div>
                  <div>
                    <dt>Outcome</dt>
                    <dd>{project.outcome}</dd>
                  </div>
                </dl>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
