---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { withBase } from '../utils/paths';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<BaseLayout
  title="Mao Ratha"
  description="Senior UX/UI Designer and leader. Mao Ratha builds clear products, publishes thoughtful writing, and helps creators through education and media."
  ogTitle="Mao Ratha — UX/UI Designer & Leader"
>
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <p class="label hero__label">UX/UI Designer · Leader · Builder</p>
        <h1>Build things that <span class="hero__accent">matter.</span></h1>
        <p class="lead">
          I design products and systems that stay simple under pressure—then
          share what I learn in public.
        </p>
        <div class="hero__actions">
          <a href="#contact" class="btn btn--primary">Get in touch</a>
          <a href={withBase('/about')} class="hero__link">About me →</a>
        </div>
      </div>
      <figure class="hero__media">
        <img
          src={withBase('/ratha.png')}
          alt="Portrait of Mao Ratha"
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header">
        <span class="label">Positioning</span>
        <h2>Clarity over complexity.</h2>
      </div>
      <p class="about-intro pull-quote">
        For over a decade, I've worked at the intersection of design,
        product, and education. I believe the best work is simple, honest, and
        built to last—whether that's an interface, a case study, or a note in
        the garden.
      </p>
      <p>
        This site is a snapshot of that work. Deeper writing lives in
        <a href={withBase('/thoughts')}>Thoughts</a>.
      </p>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="section-header">
        <span class="label">Selected work</span>
        <h2>Projects</h2>
      </div>
      <div class="project-preview-grid">
        {
          projects.map((project) => (
            <article class="project-preview">
              <h3>
                <a href={withBase(`/projects/${project.id}/`)}>
                  {project.data.title}
                </a>
              </h3>
              <p>{project.data.description}</p>
            </article>
          ))
        }
      </div>
      <p class="mt-3xl">
        <a href={withBase('/projects')} class="text-link">View all projects</a>
      </p>
    </div>
  </section>

  <section class="contact" id="contact">
    <div class="container">
      <span class="label">Contact</span>
      <h2>Let's work together</h2>
      <p class="lead">
        Have a UX/UI project or need consulting? I'd love to hear about it.
      </p>
      <ContactForm />
    </div>
  </section>
</BaseLayout>
