---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactCard from '../components/ContactCard.astro';
import { withBase } from '../utils/paths';
import { formatDate } from '../utils/date';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const thoughts = (await getCollection('thoughts'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Mao Ratha"
  description="Senior UX/UI Designer and leader. Mao Ratha builds clear products, publishes thoughtful writing, and helps creators through education and media."
  ogTitle="Mao Ratha — UX/UI Designer & Leader"
>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <p class="label hero__label">UX/UI Designer · Leader · Builder</p>
        <h1>Build things that <span class="hero__accent">matter.</span></h1>
        <p class="lead">
          I design products and systems that stay simple under pressure—then
          share what I learn in public.
        </p>
        <div class="hero__actions">
          <a href="#contact" class="btn btn--primary">Get in touch</a>
          <a href={withBase('/about')} class="hero__link">About me →</a>
        </div>
      </div>
      <figure class="hero__media">
        <img
          src="/ratha.png"
          alt="Portrait of Mao Ratha"
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <!-- Work Section -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="label">Selected work</span>
        <h2>Work</h2>
      </div>
      <div class="project-preview-grid">
        {
          projects.map((project) => (
            <article class="project-preview">
              <h3>
                <a href={withBase(`/projects/${project.id}/`)}>
                  {project.data.title}
                </a>
              </h3>
              <p>{project.data.description}</p>
            </article>
          ))
        }
      </div>
      <p class="mt-3xl">
        <a href={withBase('/projects')} class="text-link">View all projects</a>
      </p>
    </div>
  </section>

  <!-- Experience Section -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="label">Career</span>
        <h2>Experience</h2>
      </div>
      <ul class="experience-list">
        <li>
          <div>
            <img src="/logos/canadia.jpg" alt="Canadia Bank Plc." class="company-logo" />
            <strong>Senior UX/UI Lead | Canadia Bank Plc.</strong>
            <span class="period">Sep 2023 – Feb 2026</span>
            <p>
              Hands-on with bank project, collaborating with developers, product owners, and QA. Recruited and managed a team of four designers. Oversaw UX work, including graphic and motion design.
            </p>
          </div>
        </li>
        <li>
          <div>
            <img src="/logos/wing.jpg" alt="Wing Bank (Cambodia) Plc." class="company-logo" />
            <strong>UX/UI Lead | Wing Bank (Cambodia) Plc.</strong>
            <span class="period">July 2019 – Aug 2023</span>
            <p>
              Created product flows based on business and consumer needs. Kept product on trend with new creative concepts. Redesigned, brainstormed, and conducted research to improve product experience.
            </p>
          </div>
        </li>
        <li>
          <div>
            <img src="/logos/mra.jpg" alt="Melon Rouge Agency" class="company-logo" />
            <strong>Digital UX/UI Designer | Melon Rouge Agency</strong>
            <span class="period">Mar 2017 – Jun 2019</span>
            <p>
              Designed mobile apps, websites, and communication for agency clients. Collaborated with creative directors to achieve client satisfaction.
            </p>
          </div>
        </li>
      </ul>
      <p class="mt-3xl">
        <a href={withBase('/about')} class="text-link">View full experience</a>
      </p>
    </div>
  </section>

  <!-- Thought Section -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="label">Writing</span>
        <h2>Thoughts</h2>
      </div>
      <ul class="thought-list">
        {
          thoughts.map((entry) => (
            <li class="thought-item">
              <article>
                <h2>
                  <a href={withBase(`/thoughts/${entry.id}/`)}>
                    {entry.data.title}
                  </a>
                </h2>
                <p class="muted">
                  <time datetime={entry.data.date.toISOString()}>
                    {formatDate(entry.data.date, true)}
                  </time>
                </p>
                {entry.data.tags.length > 0 && (
                  <ul class="tag-list" aria-label="Tags">
                    {entry.data.tags.map((tag: string) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                )}
              </article>
            </li>
          ))
        }
      </ul>
      <p class="mt-3xl">
        <a href={withBase('/thoughts')} class="text-link">View all thoughts</a>
      </p>
    </div>
  </section>

  <!-- About Section -->
  <section>
    <div class="container">
      <div class="section-header">
        <span class="label">About</span>
        <h2>About Me</h2>
      </div>
      <div class="about-grid">
        <div class="about-bio">
          <p>
            Mao Ratha is a writer and entrepreneur who has spent the last
            decade building at the intersection of content and commerce. What
            started as a side project—a weekly newsletter and a handful of
            podcast episodes—grew into a studio serving tens of thousands of
            independent creators.
          </p>
          <p>
            Their work spans education, media, and digital products. Mao is known
            for a direct voice, minimal design sensibility, and a bias toward
            shipping over strategizing. They live and work remotely, splitting
            time between writing, building, and long walks without headphones.
          </p>
        </div>
        <div class="about-skills">
          <h3>Skills & Tools</h3>
          <ul class="skills-list">
            <li>UX/UI Design</li>
            <li>Design Systems</li>
            <li>User Research</li>
            <li>Prototyping</li>
            <li>Figma</li>
            <li>Adobe Creative Suite</li>
            <li>Team Leadership</li>
            <li>Product Strategy</li>
          </ul>
        </div>
      </div>
      <p class="mt-3xl">
        <a href={withBase('/about')} class="text-link">Learn more about me</a>
      </p>
    </div>
  </section>

  <!-- Footer/Contact Section -->
  <ContactCard />
</BaseLayout>
