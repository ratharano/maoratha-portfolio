---
import BaseLayout from './BaseLayout.astro';
import { withBase } from '../utils/paths';

interface Props {
  title: string;
  date: Date;
  tags: string[];
}

const { title, date, tags } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={`Thoughts by Mao Ratha — ${title}`}>
  <header class="page-header">
    <div class="container">
      <p class="label">Thought</p>
      <h1>{title}</h1>
      <p class="muted">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </p>
      {
        tags.length > 0 && (
          <ul class="tag-list" aria-label="Tags">
            {tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        )
      }
    </div>
  </header>

  <section>
    <div class="container content-body">
      <slot />
    </div>
  </section>

  <section>
    <div class="container">
      <p>
        <a href={withBase('/thoughts')} class="text-link">← All thoughts</a>
      </p>
    </div>
  </section>
</BaseLayout>
