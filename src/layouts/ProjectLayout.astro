---
import BaseLayout from './BaseLayout.astro';
import { withBase } from '../utils/paths';

interface Props {
  title: string;
  description: string;
  role: string;
  outcome: string;
  date: Date;
}

const { title, description, role, outcome, date } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<BaseLayout title={title} description={description}>
  <header class="page-header">
    <div class="container">
      <p class="label">Project</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <p class="muted">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </p>
      <dl class="project-meta project-meta--inline">
        <div>
          <dt>Role</dt>
          <dd>{role}</dd>
        </div>
        <div>
          <dt>Outcome</dt>
          <dd>{outcome}</dd>
        </div>
      </dl>
    </div>
  </header>

  <section>
    <div class="container content-body">
      <slot />
    </div>
  </section>

  <section>
    <div class="container">
      <p>
        <a href={withBase('/projects')} class="text-link">← All projects</a>
      </p>
    </div>
  </section>
</BaseLayout>
